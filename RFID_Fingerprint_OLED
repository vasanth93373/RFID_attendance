void doubleBeep3Times() {
  for (int i = 0; i < 3; i++) {

    digitalWrite(BUZZER_PIN, HIGH);
    delay(120);
    digitalWrite(BUZZER_PIN, LOW);
    delay(120);

    digitalWrite(BUZZER_PIN, HIGH);
    delay(120);
    digitalWrite(BUZZER_PIN, LOW);
    delay(300);
  }
}

void checkBellSchedule() {

  DateTime now = rtc.now();

  // Reset daily
  if (now.day() != lastDay) {
    lastDay = now.day();

    for (int i = 0; i < bellCount; i++) {
      bells[i].rung = false;
    }
  }

  // Check all bell times
  for (int i = 0; i < bellCount; i++) {

    if (!bells[i].rung &&
        now.hour() == bells[i].hour &&
        now.minute() == bells[i].minute &&
        now.second() == 0) {

      doubleBeep3Times();
      bells[i].rung = true;
    }
  }
}
