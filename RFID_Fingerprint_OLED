bool connectWiFi()
{
  WiFi.mode(WIFI_STA);

  for(int i = 0; i < wifiCount; i++)
  {
    oledMessage(
      "Trying WiFi",
      ssidList[i]
    );

    WiFi.begin(ssidList[i], passList[i]);

    unsigned long startTime = millis();

    while(WiFi.status() != WL_CONNECTED &&
          millis() - startTime < 10000)
    {
      delay(500);
    }

    if(WiFi.status() == WL_CONNECTED)
    {
      oledMessage(
        "Connected",
        ssidList[i]
      );

      delay(1000);
      return true;
    }

    WiFi.disconnect(true);
    delay(500);
  }

  oledMessage(
    "No WiFi",
    "Available"
  );

  return false;
}

