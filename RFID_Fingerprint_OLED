void exportAttendance()
{
  tripleBeep();

  if (!connectWiFi())
  {
    delay(2000);

    oledMessage(
      "Upload Failed",
      "No Internet"
    );

    delay(2000);

    oledMessage(
      "IV ECE D",
      "Attendance System",
      "Scan Your ID Card"
    );

    return;
  }

  oledMessage(
    "Uploading",
    "Attendance..."
  );

  // ==========================
  // ATTENDANCE SHEET
  // ALL STUDENTS
  // ==========================

  for(int i = 0; i < studentCount; i++)
  {
    String status =
      attendance[i].present ?
      "Present" :
      "Absent";

    String timeValue =
      attendance[i].present ?
      String(attendance[i].time) :
      "--";

    sendToGoogleSheet(
      "Attendance",
      students[i].roll,
      students[i].name,
      status,
      timeValue
    );

    delay(500);
  }

  // ==========================
  // ABSENT SHEET
  // ONLY ABSENT STUDENTS
  // ==========================

  for(int i = 0; i < studentCount; i++)
  {
    if(!attendance[i].present)
    {
      sendToGoogleSheet(
        "Absent",
        students[i].roll,
        students[i].name,
        "Absent",
        "--"
      );

      delay(500);
    }
  }

  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);

  oledMessage(
    "Upload",
