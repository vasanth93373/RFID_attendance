bool enrollFingerprintWithRetry(uint16_t id, String fingerName)
{
  while (true)
  {
    oledMessage("Place " + fingerName);

    if (enrollFingerprint(id))
      return true;

    fiveBeep();

    oledMessage(
      fingerName + " Failed",
      "Press RESCAN",
      "or CLEAR Exit"
    );

    while (true)
    {
      if (digitalRead(RESCAN_BTN) == LOW)
      {
        delay(300);
        while (digitalRead(RESCAN_BTN) == LOW);
        break;   // retry same finger
      }

      if (digitalRead(CLEAR_BTN) == LOW)
      {
        delay(300);
        while (digitalRead(CLEAR_BTN) == LOW);

        finger.deleteModel(id);

        oledMessage(
          "Enrollment",
          "Cancelled"
        );

        delay(2000);

        return false;
      }

      delay(50);
    }
  }
}

